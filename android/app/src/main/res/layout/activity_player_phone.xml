<?xml version="1.0" encoding="utf-8"?>
<!-- 手机端播放器：全屏 + 手势提示 + 频道信息 -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- 播放器 -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit"
        app:use_controller="true"
        app:show_timeout="3000"
        app:show_buffering="when_playing" />

    <!-- 缓冲指示器 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent"
        android:visibility="gone" />

    <!-- 频道信息覆盖层（左上角） -->
    <LinearLayout
        android:id="@+id/layoutChannelInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:background="@drawable/bg_channel_info"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvChannelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStreamType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#aaa"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvResolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888"
                android:textSize="11sp"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- EPG 节目信息 -->
        <LinearLayout
            android:id="@+id/layoutEpg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvEpgNow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ccc"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvEpgNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 手势提示浮层 (首次使用时显示) -->
    <LinearLayout
        android:id="@+id/layoutGestureHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_channel_info"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="操作说明"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👆 单击：显示/隐藏信息\n✌️ 双击：播放/暂停\n👈👉 左右滑动：切换频道\n👆👇 上下滑动：音量/亮度\n⏳ 长按：倍速播放"
            android:textColor="#ddd"
            android:textSize="13sp"
            android:lineSpacingExtra="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击任意位置关闭"
            android:textColor="#888"
            android:textSize="11sp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- 音量指示器（右边缘） -->
    <LinearLayout
        android:id="@+id/layoutVolumeIndicator"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressVolume"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="6dp"
            android:layout_height="120dp"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="#333"
            android:rotation="270" />

        <TextView
            android:id="@+id/tvVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#aaa"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 亮度指示器（左边缘） -->
    <LinearLayout
        android:id="@+id/layoutBrightnessIndicator"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBrightness"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="6dp"
            android:layout_height="120dp"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/warn"
            android:progressBackgroundTint="#333"
            android:rotation="270" />

        <TextView
            android:id="@+id/tvBrightness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#aaa"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:text="☀" />
    </LinearLayout>

    <!-- 倍速指示器 -->
    <TextView
        android:id="@+id/tvSpeedIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:textColor="@color/accent"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_channel_info"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:visibility="gone" />

</FrameLayout>
