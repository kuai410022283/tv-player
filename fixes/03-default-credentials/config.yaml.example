# ========================================
# config.yaml — 安全配置模板
# ========================================
# ⚠️  首次部署前必须修改以下配置项！
#
# 生成管理员密码哈希:
#   go run cmd/hash-password/main.go "你的密码"
#
# 生成 JWT secret:
#   openssl rand -hex 32

server:
  host: "0.0.0.0"
  port: 9527

database:
  path: "./data/tvplayer.db"

stream:
  cache_dir: "./data/cache"
  max_concurrent: 50
  buffer_size: 4096
  health_check_sec: 30

auth:
  # JWT 密钥（必须修改！留空则自动生成，但重启后会变化）
  secret: ""
  # Token 有效期（小时）
  expire_hours: 720
  # 管理员密码（推荐使用 bcrypt 哈希，明文也兼容但不推荐）
  # 生成哈希: go run cmd/hash-password/main.go "你的密码"
  admin_password: ""

# CORS 配置（生产环境建议限制为实际域名）
cors:
  allowed_origins:
    - "*"
